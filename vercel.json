{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "cd Phytospectra && npm run build",
  "devCommand": "cd Phytospectra && npm run dev",
  "installCommand": "cd Phytospectra && npm install",
  "outputDirectory": "Phytospectra/dist",
  "framework": "vite",
  "rewrites": [{ "source": "/(.*)", "destination": "/index.html" }]
}
